# ============================================================
# Fable Video Pipeline — Environment Configuration
# ============================================================
# Copy to .env:  cp .env.example .env
# Then fill in your actual values.
# ============================================================

# ── SenseNova 图像生成 ──────────────────────────────────────
# 获取 API Key: https://platform.sensenova.cn
SN_IMAGE_GEN_API_KEY=your_api_key_here
SN_BASE_URL=https://api.sensenova.cn/v1

# ── 图像生成参数（可选，脚本有默认值）─────────────────────────
# 模型: sensenova-u1-fast
SN_IMAGE_MODEL=sensenova-u1-fast
# 图片尺寸: 2k
DEFAULT_IMAGE_SIZE=2k
# 画幅比例: 16:9
DEFAULT_ASPECT_RATIO=16:9
# 单图请求超时（秒）: 900
IMAGE_TIMEOUT=900

# ── Edge-TTS 配音（无需 API Key，免费）────────────────────────
# 默认音色: en-US-GuyNeural
DEFAULT_VOICE=en-US-GuyNeural

# ── 视频参数（可选，脚本有默认值）────────────────────────────
WIDTH=1920
HEIGHT=1080
FPS=24
PIX_FMT=yuv420p

# ── 字幕字体（按优先级搜索，脚本会自动检测）──────────────────
# 默认搜索路径:
#   /usr/share/fonts/truetype/noto/NotoSansCJK-Regular.ttc
#   /usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc
#   /usr/share/fonts/noto-cjk/NotoSansCJK-Regular.ttc
#   /usr/share/fonts/truetype/wqy/wqy-zenhei.ttc
# 如需指定特定字体，取消下方注释并填入绝对路径:
# CUSTOM_FONT_PATH=/usr/share/fonts/your-font.ttc

# ── 分镜类型（跳过图片生成的类型）────────────────────────────
# 默认: title, moral, subtitle, quote
# SKIP_IMAGE_TYPES=title,moral,subtitle,quote

[Script Info]
; ASS Subtitle Template for Bilingual Fable Videos
; Usage: Generate dynamically in Python, then pass to ffmpeg subtitles filter
;
; Key parameters:
; - PlayResX/PlayResY: Must match video resolution (1920x1080)
; - CN style: Noto Serif SC, 44px, bold, white with black shadow
; - EN style: Arial, 32px, regular, white with black shadow
; - \pos(x,y): Exact pixel positioning (960 = horizontal center)
; - MarginV: Vertical margin from bottom (CN=80, EN=150)
;
; Position guide (1920x1080):
;   y=970 → Chinese subtitle (110px from bottom)
;   y=1020 → English subtitle (60px from bottom)
;   Spacing: 50px between lines

ScriptType: v4.00+
PlayResX: 1920
PlayResY: 1080

[V4+ Styles]
Format: Name, Fontname, Fontsize, PrimaryColour, SecondaryColour, OutlineColour, BackColour, Bold, Italic, Underline, StrikeOut, ScaleX, ScaleY, Spacing, Angle, BorderStyle, Outline, Shadow, Alignment, MarginL, MarginR, MarginV, Encoding
Style: CN,Noto Serif SC,44,&H00FFFFFF,&H000000FF,&H00000000,&H00000000,1,0,0,0,100,100,0,0,3,2,2,2,10,10,80,1
Style: EN,Arial,32,&H00FFFFFF,&H000000FF,&H00000000,&H00000000,0,0,0,0,100,100,0,0,3,1,1,2,10,10,150,1

[Events]
Format: Layer, Start, End, Style, Name, MarginL, MarginR, MarginV, Effect, Text
; Example dialogue line - replace with actual content
Dialogue: 0,0:00:00.00,0:00:05.000,CN,,10,10,80,,{\pos(960,970)}朝三暮四
Dialogue: 0,0:00:00.00,0:00:05.000,EN,,10,10,150,,{\pos(960,1020)}Three in the Morning, Four in the Evening
